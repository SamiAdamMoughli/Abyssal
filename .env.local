# Local development overrides (no Docker).
# Source this before running: source .env.local
# Or pass it to uvicorn/celery: --env-file .env.local

DATA_SOURCE=synthetic
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://spyhop:spyhop@127.0.0.1/spyhop
SYNC_DATABASE_URL=postgresql+psycopg2://spyhop:spyhop@127.0.0.1/spyhop

REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

PYTHONPATH=/home/sami/dev/Abyssal/src:/home/sami/dev/Abyssal
