# =============================================================================
# .env.dev — Development environment
# Used by: docker compose up (via docker-compose.override.yml)
# Copy to .env:  cp .env.dev .env
# =============================================================================

APP_NAME=VesselX
DATA_SOURCE=synthetic
LOG_LEVEL=DEBUG

# PostgreSQL (matches docker-compose service names)
DATABASE_URL=postgresql+asyncpg://vesselx:vesselx@vesselx-core-db:5432/vesselx
SYNC_DATABASE_URL=postgresql+psycopg2://vesselx:vesselx@vesselx-core-db:5432/vesselx
SHIPBOARD_DATABASE_URL=postgresql+asyncpg://vesselx:vesselx@vesselx-shipboard-store:5432/vesselx_shipboard
SYNC_SHIPBOARD_DATABASE_URL=postgresql+psycopg2://vesselx:vesselx@vesselx-shipboard-store:5432/vesselx_shipboard

# Redis
REDIS_URL=redis://vesselx-telemetry-cache:6379/0
CELERY_BROKER_URL=redis://vesselx-telemetry-cache:6379/1
CELERY_RESULT_BACKEND=redis://vesselx-telemetry-cache:6379/2

# Global Fishing Watch — AIS/vessel data
GFW_API_TOKEN=your_gfw_token_here
GFW_BBOX=-95.0,-5.0,-80.0,10.0
GFW_LOOKBACK_HOURS=168
GFW_HTTP_TIMEOUT=60

# Global Forest Watch Data API — protected areas
GFW_API_KEY=your_gfw_data_api_key_here
GFW_API_ORIGIN=http://localhost
PROTECTED_AREA_SOURCE=gfw

# aisstream.io — live AIS WebSocket
AISSTREAM_API_KEY=your_aisstream_key_here
AISSTREAM_FLUSH_INTERVAL=10

# Tuning
VESSEL_CACHE_TTL=60
VESSEL_STREAM_POLL_SECONDS=3
