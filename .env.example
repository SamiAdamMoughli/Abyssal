# Mission Radar - Beispiel-Umgebung.
# Kopiere diese Datei nach `.env` und trage deine Werte ein:
#     cp .env.example .env
# .env wird NICHT eingecheckt (siehe .gitignore). Niemals echte Token committen.

# --- Datenquelle --------------------------------------------------------------
# Steuert, welche Quelle die API standardmaessig nutzt: "synthetic" oder "gfw".
# Default ist "synthetic", damit das Projekt ohne Token laeuft.
DATA_SOURCE=synthetic

# --- Global FISHING Watch API (echte AIS-/Schiffsquelle, gfw_vessels.py) -------
# Token im GFW-Portal anlegen:
#     https://globalfishingwatch.org/our-apis/tokens
GFW_API_TOKEN=dein_token_hier

# Optional: Default-bbox + Zeitfenster fuer die GFW-Quelle.
# GFW_API_BASE=https://gateway.api.globalfishingwatch.org/v3
# GFW_BBOX=-91.5,-1.5,-89.5,0.5      # min_lon,min_lat,max_lon,max_lat
# GFW_LOOKBACK_HOURS=48             # letzte N Stunden (24-72 sinnvoll); ignoriert, wenn START/END gesetzt
# GFW_START=2024-01-01T00:00:00Z
# GFW_END=2024-01-03T00:00:00Z
# GFW_HTTP_TIMEOUT=30

# Optional: erst anpassen, wenn die echte API-Antwort die Werte vorgibt (Doku!).
# GFW_EVENTS_DATASET=public-global-fishing-events:latest
# GFW_EVENT_TYPE_GAP=GAP
# GFW_EVENT_TYPE_LOITERING=LOITERING

# --- Global FOREST Watch DATA API (Schutzgebiete / WDPA) ----------------------
# ACHTUNG: andere API als oben! Forest Watch (Wald/Raster/Schutzgebiete),
# liefert KEINE Schiffe. Wird nur fuer echte WDPA-Schutzgebiets-Geometrien genutzt.
# Key anlegen: POST /auth/sign-up -> POST /auth/apikey
GFW_API_KEY=dein_data_api_key_hier
# origin muss zur domains-Allowlist des Keys passen (APIKeyRequestIn.domains):
GFW_API_ORIGIN=http://localhost

# Optional: WDPA-Dataset/-Version/-Geometriespalte (mit list_datasets() ermitteln):
# GFW_DATA_API_BASE=https://data-api.globalforestwatch.org
# GFW_WDPA_DATASET=wdpa_protected_areas
# GFW_WDPA_VERSION=latest
# GFW_WDPA_GEOM_COLUMN=geom
