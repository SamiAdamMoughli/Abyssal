# Mission Radar (Spyhop) — Environment Template
# Copy to .env: cp .env.example .env
# .env is gitignored — never commit real secrets.

# ===========================================================================
# Application
# ===========================================================================
DATA_SOURCE=synthetic       # synthetic | gfw
LOG_LEVEL=INFO

# ===========================================================================
# PostgreSQL + PostGIS
# ===========================================================================
DATABASE_URL=postgresql+asyncpg://spyhop:spyhop@db:5432/spyhop
SYNC_DATABASE_URL=postgresql+psycopg2://spyhop:spyhop@db:5432/spyhop

# ===========================================================================
# Redis
# ===========================================================================
REDIS_URL=redis://redis:6379/0

# ===========================================================================
# Celery
# ===========================================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===========================================================================
# Global Fishing Watch  (vessel AIS / events)
# Token: https://globalfishingwatch.org/our-apis/tokens
# ===========================================================================
GFW_API_TOKEN=your_gfw_fishing_token_here
GFW_BBOX=-91.5,-1.0,-90.0,0.3       # min_lon,min_lat,max_lon,max_lat
GFW_HTTP_TIMEOUT=60

# ===========================================================================
# Global Forest Watch Data API  (WDPA protected areas)
# Key: POST /auth/apikey at data-api.globalforestwatch.org
# ===========================================================================
GFW_API_KEY=your_gfw_data_api_key_here
GFW_API_ORIGIN=http://localhost
PROTECTED_AREA_SOURCE=gfw
